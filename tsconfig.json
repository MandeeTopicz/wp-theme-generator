{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "paths": {
      "@wp-theme-gen/shared": ["./packages/shared/src"],
      "@wp-theme-gen/client": ["./packages/client/src"],
      "@wp-theme-gen/server": ["./packages/server/src"]
    }
  },
  "exclude": ["node_modules", "dist"]
}
